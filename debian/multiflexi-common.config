#!/bin/sh
# config script for multiflexi-common
set -e

. /usr/share/debconf/confmodule

ENV_FILE="/etc/multiflexi/multiflexi.env"

# Nothing to ask if a choice was already made (upgrade/reinstall): either a
# real key is configured, or encryption was previously disabled on purpose.
if [ -f "$ENV_FILE" ] && { grep -q "^ENCRYPTION_MASTER_KEY=" "$ENV_FILE" 2>/dev/null || grep -q "^DATA_ENCRYPTION_ENABLED=false" "$ENV_FILE" 2>/dev/null; }; then
    db_stop
    exit 0
fi

db_input medium multiflexi/encryption_master_key_source || true
db_go || true

db_get multiflexi/encryption_master_key_source
if [ "$RET" = "manual" ]; then
    db_input high multiflexi/encryption_master_key_value || true
    db_go || true
fi

db_stop

exit 0
